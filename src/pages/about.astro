---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About"
  description="About Anthony Gonzales, a Product Engineer based in New York."
>
  <h1>About</h1>

  <p>
    I'm a <a
      href="https://leerob.com/n/product-engineers"
      target="_blank"
      rel="noopener noreferrer">Product Engineer</a
    > at <a
      href="https://compass.com"
      target="_blank"
      rel="nofollow noopener noreferrer">Compass</a
    >, based in New York.
  </p>
  <p>
    I write about testing, TypeScript, and building for the web. Find me on <a
      href="https://github.com/antgonzales"
      target="_blank"
      rel="noopener noreferrer">GitHub</a
    > or <a
      href="https://www.linkedin.com/in/anthony-gonzales-5a06b994"
      target="_blank"
      rel="noopener noreferrer">LinkedIn</a
    >, or email <a href="mailto:hello@anthonygonzal.es"
      >hello@anthonygonzal.es</a
    >.
  </p>

  <p>
    My primary editor is <a
      href="https://neovim.io"
      target="_blank"
      rel="noopener noreferrer">Neovim</a
    > with <a
      href="https://www.lazyvim.org"
      target="_blank"
      rel="noopener noreferrer">LazyVim</a
    >. For notes and thinking I use <a
      href="https://obsidian.md"
      target="_blank"
      rel="noopener noreferrer">Obsidian</a
    >, along with its Pomodoro plugin to stay focused.
  </p>

  <p>
    Built with <a
      href="https://astro.build"
      target="_blank"
      rel="noopener noreferrer">Astro</a
    > and hosted on <a
      href="https://pages.cloudflare.com"
      target="_blank"
      rel="noopener noreferrer">Cloudflare Pages</a
    >. The typeface is <a
      href="https://fonts.google.com/specimen/Lora"
      target="_blank"
      rel="noopener noreferrer">Lora</a
    >.
  </p>
</BaseLayout>
