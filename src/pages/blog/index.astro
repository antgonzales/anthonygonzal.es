---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/formatDate";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog" description="All posts by Anthony Gonzales.">
  <h1>Blog</h1>
  <ul
    class="divide-y divide-[var(--color-border)] list-none p-0 m-0"
    itemscope
    itemtype="https://schema.org/Blog"
  >
    {
      posts.map((post) => (
        <li
          class="flex justify-between items-baseline gap-6 py-4"
          itemprop="blogPost"
          itemscope
          itemtype="https://schema.org/BlogPosting"
        >
          <a href={`/blog/${post.id}/`} class="no-underline" itemprop="url">
            <span itemprop="headline">{post.data.title}</span>
          </a>
          <time
            datetime={post.data.pubDate.toISOString()}
            class="text-[var(--color-meta)] shrink-0"
            itemprop="datePublished"
          >
            {formatDate(post.data.pubDate)}
          </time>
        </li>
      ))
    }
  </ul>
</BaseLayout>
