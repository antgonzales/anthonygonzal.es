---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate } from "../lib/formatDate";
import { getExcerpt } from "../lib/getExcerpt";

const allPosts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [latest, ...rest] = allPosts;
const recentPosts = rest.slice(0, 3);
---

<BaseLayout
  title="Anthony Gonzales"
  description="The personal site, blog, and portfolio of Anthony Gonzales, a developer who cares about the code."
>
  <!-- Bio -->
  <section class="mb-10" itemscope itemtype="https://schema.org/Person">
    <p>
      I'm a <a
        href="https://leerob.com/n/product-engineers"
        target="_blank"
        rel="noopener noreferrer">Product Engineer</a
      > at <a
        href="https://compass.com"
        target="_blank"
        rel="nofollow noopener noreferrer">Compass</a
      >, based in New York.
    </p>
    <p>
      I write about testing, TypeScript, and building for the web. Find me on <a
        href="https://github.com/antgonzales"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      > or <a
        href="https://www.linkedin.com/in/anthony-gonzales-5a06b994"
        target="_blank"
        rel="noopener noreferrer">LinkedIn</a
      >, or email <a href="mailto:hello@anthonygonzal.es"
        >hello@anthonygonzal.es</a
      >.
    </p>
  </section>

  <!-- Posts -->
  <section itemscope itemtype="https://schema.org/Blog">
    <!-- Latest post -->
    <div class="not-prose flex items-center gap-4 mb-6">
      <h2 class="m-0 text-base whitespace-nowrap">Latest post</h2>
      <hr class="flex-1 border-t border-[var(--color-border)] m-0" />
    </div>

    {
      latest && (
        <article
          itemscope
          itemtype="https://schema.org/BlogPosting"
          class="mb-12"
        >
          <h2 class="mt-0 mb-2">
            <a
              href={`/blog/${latest.id}/`}
              class="no-underline"
              itemprop="url headline"
            >
              {latest.data.title}
            </a>
          </h2>
          <time
            datetime={latest.data.pubDate.toISOString()}
            class="text-[var(--color-meta)]"
            itemprop="datePublished"
          >
            {formatDate(latest.data.pubDate)}
          </time>
          <p itemprop="description">{getExcerpt(latest.body ?? "")}</p>
          <a href={`/blog/${latest.id}/`} class="no-underline">
            Read more &rarr;
          </a>
        </article>
      )
    }

    <!-- Previous posts -->
    <div class="not-prose flex items-center gap-4 mb-6">
      <h2 class="m-0 text-base whitespace-nowrap">Previous posts</h2>
      <hr class="flex-1 border-t border-[var(--color-border)] m-0" />
    </div>

    {
      recentPosts.length > 0 && (
        <ul class="list-none p-0 m-0">
          {recentPosts.map((post) => (
            <li class="flex justify-between items-baseline gap-6 py-2">
              <a href={`/blog/${post.id}/`} class="no-underline">
                {post.data.title}
              </a>
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-[var(--color-meta)] shrink-0"
              >
                {formatDate(post.data.pubDate)}
              </time>
            </li>
          ))}
        </ul>
      )
    }
    <a href="/blog/" class="no-underline">All posts &rarr;</a>
  </section>
</BaseLayout>
