---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  pubDate?: Date;
  updatedDate?: Date;
}

const { title, description, ogImage, pubDate, updatedDate } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = "Anthony Gonzales";
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href="/rss.xml"
    />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}

    <!-- Open Graph -->
    <meta property="og:type" content={pubDate ? "article" : "website"} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    {description && <meta property="og:description" content={description} />}
    {
      ogImage && (
        <meta property="og:image" content={new URL(ogImage, Astro.site)} />
      )
    }
    {
      pubDate && (
        <meta
          property="article:published_time"
          content={pubDate.toISOString()}
        />
      )
    }
    {
      updatedDate && (
        <meta
          property="article:modified_time"
          content={updatedDate.toISOString()}
        />
      )
    }

    <!-- Twitter card -->
    <meta
      name="twitter:card"
      content={ogImage ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {
      ogImage && (
        <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
      )
    }

    <!-- No-flash dark mode init — must run before first paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body>
    <!-- Nav -->
    <header class="mt-10 mb-10">
      <div
        class="max-w-3xl mx-auto px-6 flex justify-between items-center w-full"
      >
        <a
          href="/"
          aria-label="Anthony Gonzales home"
          class="text-[var(--color-nav)] leading-tight no-underline hover:no-underline"
        >
          <span>Anthony Gonzales</span>
        </a>

        <!-- Nav links -->
        <nav class="flex items-center gap-4 p-0 m-0">
          <a href="/blog/" class="text-[var(--color-text)]">Blog</a>
          <ThemeToggle />
        </nav>
      </div>
    </header>

    <!-- Main content -->
    <main
      class="prose prose-neutral dark:prose-invert prose-headings:font-normal max-w-3xl mx-auto px-6 pb-24 w-full"
    >
      <slot />
    </main>
  </body>
</html>
