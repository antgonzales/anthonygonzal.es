---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/formatDate';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
---

<BaseLayout
  title={title}
  description={description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  ogImage={heroImage?.src}
>
  <article itemscope itemtype="https://schema.org/BlogPosting" class="pt-7">
    <!-- Post header -->
    <header class="mb-6">
      <h1 itemprop="headline">
        {title}
      </h1>
      <div class="text-[var(--color-meta)]">
        <time itemprop="datePublished" datetime={pubDate.toISOString()}>
          {formatDate(pubDate)}
        </time>
        {updatedDate && (
          <span class="italic">
            &ensp;&middot;&ensp; Updated{' '}
            <time itemprop="dateModified" datetime={updatedDate.toISOString()}>
              {formatDate(updatedDate)}
            </time>
          </span>
        )}
      </div>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-3">
          {tags.map((tag) => (
            <span class="text-[var(--color-meta)] border border-[var(--color-border)] px-2 py-0.5 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- Hero image -->
    {heroImage && (
      <Image
        src={heroImage}
        alt={title}
        class="w-full h-auto rounded mb-8"
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, 768px"
      />
    )}

    <!-- Post body -->
    <div itemprop="articleBody" class="mb-16">
      <slot />
    </div>

    <!-- Post footer -->
    <footer class="mt-12 pt-6 border-t border-[var(--color-border)]">
      <a
        href={`https://github.com/antgonzales/anthonygonzal.es/blob/main/src/content/posts/${slug}.md`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-meta)] underline hover:text-[var(--color-link)]"
      >
        Suggest a correction
      </a>
    </footer>
  </article>
</BaseLayout>
