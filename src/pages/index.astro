---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate } from "../lib/formatDate";
import { getExcerpt } from "../lib/getExcerpt";

const allPosts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [latest, ...rest] = allPosts;
---

<BaseLayout
  title="Anthony Gonzales"
  description="The personal site and blog of Anthony Gonzales, a Product Engineer based in New York."
>
  <!-- Posts -->
  <section itemscope itemtype="https://schema.org/Blog">
    {
      latest && (
        <article
          itemscope
          itemtype="https://schema.org/BlogPosting"
          class="mb-12"
        >
          <h2 class="mt-0 mb-2">
            <a
              href={`/blog/${latest.id}/`}
              class="no-underline"
              itemprop="url headline"
            >
              {latest.data.title}
            </a>
          </h2>
          <time
            datetime={latest.data.pubDate.toISOString()}
            class="italic text-[var(--color-meta)]"
            itemprop="datePublished"
          >
            {formatDate(latest.data.pubDate)}
          </time>
          <p itemprop="description">{getExcerpt(latest.body ?? "")}</p>
          <a href={`/blog/${latest.id}/`} class="no-underline">
            Read more &rarr;
          </a>
        </article>
      )
    }

    {
      rest.length > 0 && (
        <ul class="not-prose list-none p-0 m-0">
          {rest.map((post) => (
            <li class="flex justify-between items-baseline gap-6 py-2">
              <a href={`/blog/${post.id}/`} class="no-underline">
                {post.data.title}
              </a>
              <time
                datetime={post.data.pubDate.toISOString()}
                class="italic text-[var(--color-meta)] shrink-0"
              >
                {formatDate(post.data.pubDate)}
              </time>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
